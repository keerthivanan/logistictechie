# ============================================================
# OMEGO LOGISTICS OS — .gitignore
# ============================================================

# === PYTHON ===
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# === VIRTUAL ENVIRONMENTS ===
venv/
.venv/
env/
backend/venv/

# === NODE / NEXT.JS ===
node_modules/
.next/
out/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# === ENVIRONMENT & SECRETS — NEVER COMMIT ===
.env
.env.local
.env.development
.env.test
.env.production
.env.development.local
.env.test.local
.env.production.local
backend/.env
*.env

# === SENSITIVE CREDENTIAL FILES — NEVER COMMIT ===
google-credentials.json
*credentials*.json
*-credentials.json
*service-account*.json
*service_account*.json

# === CLAUDE CODE (AI ASSISTANT INTERNALS) ===
.claude/

# === IDE & OS ===
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# === LOGS & TEMP FILES ===
*.log
*.tmp
*.bak

# === BACKEND GENERATED / ONE-OFF SCRIPTS ===
backend/alembic/versions/
backend/data/
backend/scripts/
scripts/
audit.py
generate_tree.py
full_tree.txt
verify_maersk.py
verify_platform.py
definitive_schema_audit.json
handshake*.txt
test_out.txt
test_results.txt

# === VERCEL DEPLOYMENT ===
.vercel/
!frontend/.vercel/
!frontend/.vercelignore
!frontend/vercel.json
