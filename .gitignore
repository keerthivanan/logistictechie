.installed.cfg
*.egg

# === VIRTUAL ENVIRONMENTS ===
venv/
.venv/
env/
backend/venv/

# === NODE / NEXT.JS ===
node_modules/
.next/
out/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# === ENVIRONMENT & SECRETS — NEVER COMMIT ===
.env
.env.local
.env.development
.env.test
.env.production
.env.development.local
.env.test.local
.env.production.local
backend/.env
*.env

# === SENSITIVE CREDENTIAL FILES — NEVER COMMIT ===
google-credentials.json
*credentials*.json
*-credentials.json
*service-account*.json
*service_account*.json

# === CLAUDE CODE (AI ASSISTANT INTERNALS) ===
.claude/

# === IDE & OS ===
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# === LOGS & TEMP FILES ===
*.log
*.tmp
*.bak

# === N8N AUTOMATION — JSON workflows are committed so VPS can pull them ===
# Ignore only the planning/guide docs, keep the JSON workflow files
n8n_plan/*.md

# === PROJECT PLANS & AGENT METADATA (CONFIDENTIAL) ===
plan/
tmp/
.agent/
.gemini/
.agent/logs/
.agent/tasks/
plan/*.md
!README.md
!backend/README.md
!frontend/README.md

# === SCRATCH SCRIPTS (IGNORE) ===
parse_wf1.py
parse_wf1b.py
pydantic_tables_v2.py
v1_schema.sql
audit.py
generate_tree.py
full_tree.txt
verify_maersk.py
