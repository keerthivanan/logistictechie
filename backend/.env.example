# OMEGO LOGISTICS OS - ENVIRONMENT TEMPLATE
# ==========================================
# Copy this file to .env and populate with real keys.

# 1. CORE SECURITY
# Generate a 64-character random string (e.g. openssl rand -hex 32)
SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# 2. DATABASE CONFIGURATION
# Format: postgresql+asyncpg://user:password@host:port/dbname
# LOCAL DEV:  postgresql+asyncpg://postgres:postgres@localhost:5432/logistics_db
# DOCKER:     postgresql+asyncpg://postgres:postgres@postgres:5432/logistics_db  ← use service name, not localhost
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/logistics_db

# 3. CARRIER INTEGRATIONS (MAERSK ONLY)
# Get keys from Maersk Developer Portal (Point-to-Point API)
MAERSK_CONSUMER_KEY=
MAERSK_CONSUMER_SECRET=
MAERSK_INTEGRATION_ID=

# 4. AI & INTELLIGENCE
# Required for CreativeCortex AI features
OPENAI_API_KEY=
REDIS_URL=redis://localhost:6379/0
QDRANT_HOST=localhost
QDRANT_PORT=6333

# 5. GOOGLE ENTERPRISE
GOOGLE_API_KEY=
GOOGLE_CLOUD_PROJECT=
GOOGLE_APPLICATION_CREDENTIALS=

# 6. EXTERNAL SERVICES
STRIPE_SECRET_KEY=
SENDGRID_API_KEY=

# 7. N8N WEBHOOKS
N8N_MARKETPLACE_SUBMIT_WEBHOOK=        # WF1 — broadcasts request to all forwarders
N8N_FORWARDER_REGISTER_WEBHOOK=        # WF5 — notifies admin + sends "application received" email to forwarder
N8N_FORWARDER_DECISION_WEBHOOK=        # WF5b — sends APPROVED or REJECTED email to forwarder
N8N_BOOKING_WEBHOOK=                   # WF6 — sends booking confirmation to both parties
N8N_QUOTES_COMPLETE_WEBHOOK=           # WF3 — sends price comparison email to shipper (3 quotes)
N8N_NEW_CONVERSATION_WEBHOOK=          # WF7 — sends "shipper wants to chat" email to forwarder
N8N_BID_CONFIRMATION_WEBHOOK=          # WF2 (2nd trigger) — fires when forwarder submits quote via portal; WF2 sends confirmation email
N8N_PASSWORD_RESET_WEBHOOK=            # Password reset email — sends reset link to user
FRONTEND_URL=https://your-domain.com   # Used to build reset links in emails
OMEGO_API_SECRET=
WF3_AUTO_CLOSE_WORKFLOW_ID=
ADMIN_WHATSAPP_NUMBER=
WHATSAPP_API_TOKEN=
GOOGLE_SHEETS_FORWARDERS_DOC_ID=

# 8. FRONTEND CONFIG
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# 9. PRODUCTION / VPS — set these on server, not locally
ALLOWED_ORIGINS_RAW=https://cargolink.sa,https://www.cargolink.sa
PUBLIC_BACKEND_URL=https://api.cargolink.sa
FRONTEND_URL=https://cargolink.sa
ADMIN_EMAIL=keerthivanan.ds.ai@gmail.com
PROJECT_NAME=CargoLink Logistics OS
