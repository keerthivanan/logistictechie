        "sendTo": "={{ $json.forwarder_email }}",
        "subject": "=Deal Locked — {{ $json.reference }} | Shipper Contact Details Inside",
        "emailType": "html",
        "message": "=<!DOCTYPE html><html><head><meta charset='UTF-8'></head><body style=\"font-family:Arial,sans-serif;background:#f4f4f4;margin:0;padding:0\"><div style=\"max-width:600px;margin:20px auto;background:#fff;border-radius:12px;overflow:hidden;border:1px solid #e5e7eb\"><div style=\"background:#ffffff;padding:18px 30px;text-align:center;border-bottom:2px solid #f0f0f0\"><img src=\"https://cargolink.sa/cargolink1.png\" alt=\"CargoLink\" style=\"height:52px;width:auto;display:block;margin:0 auto\" /></div><div style=\"background:#16a34a;color:#fff;padding:32px;text-align:center\"><h1 style=\"margin:0;font-size:24px;font-weight:900;letter-spacing:2px\">🔒 Deal Locked</h1><p style=\"margin:8px 0 0;opacity:0.8;font-size:13px\">CargoLink · New Confirmed Booking</p></div><div style=\"padding:32px\"><p style=\"font-size:15px;font-weight:700;color:#111\">Hello {{ $json.forwarder_company }},</p><p style=\"color:#555;font-size:14px;line-height:1.6\">A shipper has locked the deal with you on CargoLink. Here are their direct contact details — reach out to arrange the shipment.</p><div style=\"background:#f0fdf4;border:2px solid #22c55e;border-radius:10px;padding:20px;margin:24px 0\"><h3 style=\"margin:0 0 14px;color:#15803d;font-size:15px\">👤 Shipper Contact Details</h3><table style=\"width:100%;border-collapse:collapse\"><tr><td style=\"padding:8px 0;color:#555;font-weight:600;width:140px\">Name</td><td style=\"font-weight:700;color:#111\">{{ $json.user_name }}</td></tr><tr><td style=\"padding:8px 0;color:#555;font-weight:600\">Email</td><td><a href=\"mailto:{{ $json.user_email }}\" style=\"color:#16a34a;font-weight:700\">{{ $json.user_email }}</a></td></tr><tr><td style=\"padding:8px 0;color:#555;font-weight:600\">Phone</td><td style=\"font-weight:700;color:#111\">{{ $json.user_phone || 'Not provided' }}</td></tr></table></div><div style=\"background:#f9f9f9;border:1px solid #e5e7eb;border-radius:10px;padding:20px;margin:0 0 24px\"><h3 style=\"margin:0 0 14px;color:#374151;font-size:14px\">📦 Booking Details</h3><table style=\"width:100%;border-collapse:collapse\"><tr><td style=\"padding:5px 0;color:#6b7280;width:140px\">Reference</td><td style=\"font-family:monospace;font-weight:700\">{{ $json.reference }}</td></tr><tr><td style=\"padding:5px 0;color:#6b7280\">Route</td><td>{{ $json.origin }} → {{ $json.destination }}</td></tr><tr><td style=\"padding:5px 0;color:#6b7280\">Container</td><td>{{ $json.container_type }}</td></tr><tr><td style=\"padding:5px 0;color:#6b7280\">Transit</td><td>{{ $json.transit_days }} days</td></tr><tr><td style=\"padding:5px 0;color:#6b7280\">Agreed Price</td><td style=\"font-size:18px;font-weight:900;color:#16a34a\">{{ $json.currency }} {{ $json.total_price }}</td></tr></table></div><div style=\"background:#fef3c7;border:1px solid #fcd34d;border-radius:8px;padding:16px;margin-bottom:20px\"><p style=\"margin:0;color:#92400e;font-size:13px\">⚡ <b>Action:</b> Contact the shipper directly using the details above to coordinate pickup, documentation, and shipment scheduling.</p></div><p style=\"color:#9ca3af;font-size:12px;border-top:1px solid #e5e7eb;padding-top:16px\">Use reference <b>{{ $json.reference }}</b> in all communications with the shipper.</p></div><div style=\"background:#f9fafb;padding:16px;text-align:center;font-size:11px;color:#9ca3af\">CargoLink · Freight Marketplace · Automated Booking Alert</div></div></body></html>",
        "options": {}
      },
      "id": "wf6-email-forwarder",
