      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// Gmail trigger returns capital From/Subject at top level\nvar subject = $json.Subject || $json.subject || '';\nvar from = $json.From || $json.from || '';\nvar body = $json.textPlain || $json.textHtml || '';\n\n// Try payload.headers as fallback\nif ((!subject || !from) && $json.payload && $json.payload.headers) {\n  var headers = $json.payload.headers;\n  for (var i = 0; i < headers.length; i++) {\n    if (headers[i].name === 'Subject' || headers[i].name === 'subject') subject = headers[i].value;\n    if (headers[i].name === 'From' || headers[i].name === 'from') from = headers[i].value;\n  }\n}\n\n// Use snippet as body fallback\nif (!body) body = $json.snippet || '';\n\n// Find OMEGO-XXXX-REQ-XX in subject or body\nvar regex = /[A-Z0-9-]+-REQ-\\d+/i;\nvar match = subject.match(regex) || body.match(regex);\nif (!match) throw new Error('Request ID not found. Subject: ' + subject);\n\nvar requestId = match[0].toUpperCase();\n\n// Extract sender email\nvar emailRegex = /<(.+?)>|([\\w.-]+@[\\w.-]+\\.\\w+)/;\nvar emailMatch = from.match(emailRegex);\nvar senderEmail = emailMatch ? (emailMatch[1] || emailMatch[2]) : from;\n\nreturn {\n  json: {\n    request_id: requestId,\n    sender_email: senderEmail.toLowerCase().trim(),\n    email_subject: subject,\n    email_body: body,\n    received_at: new Date().toISOString()\n  }\n};"
      },
