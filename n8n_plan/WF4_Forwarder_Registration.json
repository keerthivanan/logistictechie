    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const d = $('Code - Parse & Normalize').first().json;\n\nconst message = `*New Partner Application*\\n\\n*Company:* ${d.company_name}\\n*Contact:* ${d.contact_person}\\n*Email:* ${d.email}\\n*Phone:* ${d.phone}\\n*WhatsApp:* ${d.whatsapp}\\n*Country:* ${d.country}\\n*Specializations:* ${d.specializations}\\n*Routes:* ${d.routes}\\n*Tax ID:* ${d.tax_id}\\n*Partner ID:* ${d.forwarder_id}\\n\\nReview in admin panel: https://cargolink.sa/admin`;\n\nreturn { json: { message, phone: d.whatsapp } };"
      },
      "id": "build-whatsapp",
      "name": "Code - Build WhatsApp Message",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        680,
        300
      ]
    },
    {
      "parameters": {
        "url": "https://api.whatsapp.com/send",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"messaging_product\": \"whatsapp\",\n  \"to\": \"{{ $env.ADMIN_WHATSAPP_NUMBER }}\",\n  \"type\": \"text\",\n  \"text\": { \"body\": {{ JSON.stringify($json.message) }} }\n}",
        "options": {
          "headers": {
            "parameter": [
              {
                "name": "Authorization",
                "value": "=Bearer {{ $env.WHATSAPP_API_TOKEN }}"
              }
            ]
          }
        }
      },
      "id": "send-whatsapp",
      "name": "HTTP - Send WhatsApp to Admin",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        900,
        300
      ],
      "continueOnFail": true
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const d = $('Code - Parse & Normalize').first().json;\n\nconst emailBody = `\n<!DOCTYPE html>\n<html>\n<head>\n  <style>\n    body { font-family: Arial, sans-serif; line-height: 1.6; color: #333; background: #f4f4f4; margin: 0; padding: 0; }\n    .container { max-width: 640px; margin: 20px auto; background: white; border-radius: 8px; overflow: hidden; box-shadow: 0 4px 6px rgba(0,0,0,0.1); }\n    .header { background: linear-gradient(135deg, #2E75B6 0%, #1A5490 100%); color: white; padding: 40px 30px; text-align: center; }\n    .header h1 { margin: 0 0 10px 0; font-size: 28px; }\n    .content { padding: 40px 30px; }\n    .info-box { background: #E8F4F8; border-left: 4px solid #2E75B6; border-radius: 4px; padding: 20px; margin: 24px 0; }\n    .info-box p { margin: 6px 0; font-size: 14px; }\n    .steps { background: #f9f9f9; border-radius: 6px; padding: 20px 20px 20px 36px; margin: 20px 0; }\n    .steps li { margin-bottom: 10px; }\n    .footer { background: #f0f0f0; padding: 20px; text-align: center; font-size: 12px; color: #888; }\n  </style>\n</head>\n<body>\n  <div class=\"container\">\n    <div class=\"header\"><div style=\"text-align:center;margin-bottom:20px\"><div style=\"background:#fff;display:inline-block;border-radius:10px;padding:10px 24px\"><img src=\"https://cargolink.sa/cargolink.png\" alt=\"CargoLink\" style=\"height:52px;width:auto;display:block\" /></div></div>\n      <h1>Application Received</h1>\n      <p style=\"margin:0;font-size:16px;opacity:0.9;\">CargoLink Partner Network</p>\n    </div>\n    <div class=\"content\">\n      <p>Dear <strong>${d.contact_person}</strong>,</p>\n      <p>Thank you for applying to join the <strong>CargoLink freight partner network</strong>. We have received your application for <strong>${d.company_name}</strong> and it is currently under review.</p>\n\n      <div class=\"info-box\">\n        <p><strong>Application Reference:</strong> ${d.forwarder_id}</p>\n        <p><strong>Company:</strong> ${d.company_name}</p>\n        <p><strong>Country:</strong> ${d.country}</p>\n        <p><strong>Submitted:</strong> ${new Date().toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}</p>\n      </div>\n\n      <h3 style=\"color:#2E75B6;\">What happens next?</h3>\n      <ol class=\"steps\">\n        <li>Our team will verify your company details and documentation.</li>\n        <li>You will receive a decision by email within 2–3 business days.</li>\n        <li>If approved, you will get your Partner ID and access to the Forwarder Portal.</li>\n        <li>If we need additional information, we will reach out directly.</li>\n      </ol>\n\n      <p style=\"font-size:13px;color:#666;margin-top:30px;\">If you have any questions in the meantime, reply to this email or visit our <a href=\"https://cargolink.sa/help\" style=\"color:#2E75B6;\">Help Center</a>.</p>\n    </div>\n    <div class=\"footer\">\n      <p><strong>CargoLink Platform</strong> — Connecting shippers with the world's best freight forwarders</p>\n      <p>© 2025 CargoLink. All rights reserved.</p>\n    </div>\n  </div>\n</body>\n</html>`;\n\nreturn { json: { ...d, email_body: emailBody } };"
      },
